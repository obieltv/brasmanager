# Banco de dados Neon (PostgreSQL)
# Obtenha em: https://neon.tech → seu projeto → Connection string
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Vercel Blob (armazenamento de fotos e PDFs)
# Criado automaticamente pelo Vercel quando você adiciona o Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_...
